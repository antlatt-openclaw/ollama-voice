# Required
AUTH_TOKEN=change-me
GROQ_API_KEY=gsk_your_groq_key_here

# Optional — defaults match config.py
# SERVER_HOST=0.0.0.0
# SERVER_PORT=8001

# Ollama
# OLLAMA_URL=http://localhost:11434/v1/chat/completions
# OLLAMA_MODEL=huihui_ai/gemma-4-abliterated:e4b

# TTS — VibeVoice (primary)
# VIBEVOICE_URL=http://192.168.1.210:7860
# TTS_VOICE=custom-Beatrice-2
# TTS_SPEED=1.3
# TTS_SAMPLE_RATE=24000

# TTS — Kokoro (fallback)
# KOKORO_URL=http://192.168.1.204:8880
# KOKORO_VOICE=af_nova

# TTS — Qwen3 (final fallback)
# QWEN3_URL=http://192.168.1.204:8881
# QWEN3_VOICE=default

# Hands-free tuning
# HF_SILENCE_MS=700
# HF_MAX_LISTEN_SECS=15
# HF_MIN_AUDIO_BYTES=8000
# HF_SMART_TURN_THRESHOLD=0.5

# Default system prompt — used when no override is persisted in data/settings.json.
# Set DEFAULT_SYSTEM_PROMPT for an inline value, or DEFAULT_SYSTEM_PROMPT_FILE for a path.
# If neither is set, a generic built-in fallback is used.
# DEFAULT_SYSTEM_PROMPT=You are a helpful voice assistant.
# DEFAULT_SYSTEM_PROMPT_FILE=./data/default_prompt.txt
